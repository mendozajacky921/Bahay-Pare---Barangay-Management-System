# ============================================================
# APPLICATION
# ============================================================
APP_NAME="Barangay Management System"
APP_ENV=production
APP_URL=https://yourdomain.com
APP_SECRET=change_this_to_a_random_64_character_string

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# EMAIL (SMTP via Resend, Gmail, or any SMTP provider)
# ============================================================
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Barangay Management System"

# ============================================================
# PAYMONGO
# ============================================================
PAYMONGO_PUBLIC_KEY=pk_live_your_public_key
PAYMONGO_SECRET_KEY=sk_live_your_secret_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# SESSION
# ============================================================
SESSION_LIFETIME=1800
SESSION_NAME=barangay_session

# ============================================================
# BARANGAY INFO (editable in admin settings later)
# ============================================================
BARANGAY_NAME="Barangay Sample"
BARANGAY_MUNICIPALITY="Municipality Name"
BARANGAY_PROVINCE="Province Name"
